FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY MiniCloudConsole.sln ./
COPY MiniCloudConsole.Domain/MiniCloudConsole.Domain.csproj MiniCloudConsole.Domain/
COPY MiniCloudConsole.Data/MiniCloudConsole.Data.csproj MiniCloudConsole.Data/
COPY MiniCloudConsole.Api/MiniCloudConsole.Api.csproj MiniCloudConsole.Api/

RUN dotnet restore MiniCloudConsole.sln

COPY . .
RUN dotnet publish MiniCloudConsole.Api/MiniCloudConsole.Api.csproj \
    -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish .

ENV ASPNETCORE_URLS=http://+:8080
ENV ASPNETCORE_ENVIRONMENT=Production

EXPOSE 8080
ENTRYPOINT ["dotnet", "MiniCloudConsole.Api.dll"]
